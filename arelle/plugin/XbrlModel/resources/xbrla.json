{
  "$schema": "../oim-taxonomy-schema.json",
  "documentInfo": {
    "documentType": "https://xbrl.org/2026/module",
    "namespaces": {
      "xbrl": "https://xbrl.org/2026",
      "xbrla": "http://xbrl.org/accounting",
      "xbrlr": "https://xbrl.org/2026/report",
      "xs": "http://www.w3.org/2001/XMLSchema",
      "ref": "https://xbrl.org/2026/ref",
      "utr": "https://xbrl.org/2026/utr",
      "xbrlm": "https://xbrl.org/2026/model"
    },
    "documentNamespacePrefix": "xbrla"
  },
  "xbrlModel": {
    "name": "xbrla:accountingModule",
    "importedTaxonomies": [
            {
                "xbrlModelName": "xbrlm:base"
            }
            ],
    "dataTypes": [
      {
        "name": "xbrla:balanceType",
        "baseType": "xs:string",
        "enumeration": [
          "debit",
          "credit"
        ],
        "allowedObjects": [
          "xbrl:propertyTypeObject"
        ]
      },
      {
        "name": "xbrla:timeSeriesDataType",
        "baseType": "xs:string",
        "enumeration": [
          "Aggregated",
          "Raw"
        ]
      },
      {
        "name": "xbrla:intervalConventionType",
        "baseType": "xs:string",
        "enumeration": [
          "StartTime",
          "EndTime"
        ]
      },
      {
        "name": "xbrla:sharesType",
        "baseType": "xs:decimal"
      },
      {
        "name": "xbrla:MonetaryPerShare",
        "baseType": "xbrlr:perShare",
        "unitType": {
          "dataTypeNumerator": "xbrlr:monetary",
          "dataTypeDenominator": "xbrla:sharesType"
        },
        "allowedObjects": [
          "xbrl:conceptObject",
          "xbrl:unitObject"
        ]
      }
    ],
    "units": [
      {
        "dataType": "xbrla:sharesType",
        "name": "xbrla:shares"
      }
    ],
    "propertyTypes": [
      {
        "name": "xbrla:balance",
        "dataType": "xbrla:balanceType",
        "definitional": true,
        "allowedObjects": [
          "xbrl:conceptObject"
        ]
      },
      {
        "name": "xbrla:intervalOfMeasurement",
        "dataType": "xs:duration",
        "definitional": false,
        "allowedObjects": [
          "xbrl:domainClassObject"
        ]
      },
      {
        "name": "xbrla:timeSeriesType",
        "dataType": "xbrla:timeSeriesDataType",
        "definitional": false,
        "allowedObjects": [
          "xbrl:domainClassObject"
        ]
      },
      {
        "name": "xbrla:intervalConvention",
        "dataType": "xbrla:intervalConventionType",
        "definitional": false,
        "allowedObjects": [
          "xbrl:domainClassObject"
        ]
      },
      {
        "name": "xbrla:completeTimeSeries",
        "dataType": "xs:boolean",
        "definitional": false,
        "allowedObjects": [
          "xbrl:domainClassObject"
        ]
      },
      {
        "name": "xbrla:excludedIntervals",
        "dataType": "xbrlr:excludedIntervalsSet",
        "definitional": false,
        "allowedObjects": [
          "xbrl:domainClassObject"
        ]
      }
    ],
    "relationshipTypes": [
      {
        "name": "xbrla:instant-accrual",
        "uri": "http://xbrl.org/oim/instant-accrual",
        "cycles": "undirected",
        "sourceObjects": [
          "xbrl:conceptObject"
        ],
        "targetObjects": [
          "xbrl:conceptObject"
        ]
      },
      {
        "name": "xbrla:instant-inflow",
        "uri": "http://xbrl.org/oim/instant-inflow",
        "cycles": "undirected",
        "sourceObjects": [
          "xbrl:conceptObject"
        ],
        "targetObjects": [
          "xbrl:conceptObject"
        ],
        "constraints": [
          {
            "constraint": "relationship.source.xbrlr:dataType == relationship.target.xbrlr:dataType AND relationship.source.property.xbrla:balance == relationship.target.property.xbrla:balance AND relationship.source.xbrl:periodType == instant AND relationship.target.xbrl:periodType == duration"
          }
        ]
      },
      {
        "name": "xbrla:instant-outflow",
        "uri": "http://xbrl.org/oim/instant-outflow",
        "cycles": "none",
        "sourceObjects": [
          "xbrl:conceptObject"
        ],
        "targetObjects": [
          "xbrl:conceptObject"
        ],
        "constraints": [
          {
            "constraint": "relationship.source.xbrlr:dataType == relationship.target.xbrlr:dataType AND relationship.source.property.xbrla:balance != relationship.target.property.xbrla:balance AND relationship.source.xbrl:periodType == instant AND relationship.target.xbrl:periodType == duration"
          }
        ]
      },
      {
        "name": "xbrla:instant-contra",
        "uri": "http://xbrl.org/oim/instant-contra",
        "cycles": "undirected",
        "sourceObjects": [
          "xbrl:conceptObject"
        ],
        "targetObjects": [
          "xbrl:conceptObject"
        ]
      }
    ],
    "cubeTypes": [
      {
        "name": "xbrla:eventCube",
        "coreDimensions": [
          "xbrl:concept"
        ],
        "cubeDimensionConstraints": {
          "allowed": [
            {
              "type": "typed",
              "dataType": "xs:token",
              "minDimensions": 1,
              "maxDimensions": 1
            }
          ],
          "closed": true
        },
        "cubeNetworkConstraints": {
          "closed": false,
          "cubeNetworks": [
            {
              "relationshipType": "xbrl:concept-refDimension",
              "minNetworks": 1,
              "source": {
                "dataType": "xs:dateTime"
              },
              "target": {
                "qname": "xbrl:period"
              }
            }
          ]
        }
      },
      {
        "name": "xbrla:eventDetailsCube",
        "coreDimensions": [
          "xbrl:concept"
        ],
        "cubeDimensionConstraints": {
          "allowed": [
            {
              "type": "typed",
              "dataType": "xs:token",
              "minDimensions": 1
            }
          ],
          "closed": true
        },
        "cubeNetworkConstraints": {
          "closed": false,
          "cubeNetworks": [
            {
              "relationshipType": "xbrl:concept-refDimension",
              "minNetworks": 1,
              "source": {
                "dataType": "xs:token"
              },
              "target": {
                "objectType": "xbrl:dimensionObject"
              }
            }
          ]
        }
      },
      {
        "name": "xbrla:journalCube",
        "baseCubeType": "xbrla:eventDetailsCube"
      },
      {
        "name": "xbrla:timeSeriesCube",
        "coreDimensions": [
          "xbrl:concept",
          "xbrl:unit",
          "xbrl:entity"
        ],
        "cubeDimensionConstraints": {
          "allowed": [
            {
              "type": "typed",
              "dataType": "xs:dateTime",
              "minDimensions": 1,
              "maxDimensions": 1,
              "domainClassProperties": {
                "allowedProperties": [
                  "xbrla:intervalOfMeasurement",
                  "xbrla:timeSeriesType",
                  "xbrl:aggregation",
                  "xbrla:intervalConvention",
                  "xbrla:completeTimeSeries",
                  "xbrla:excludedIntervals"
                ],
                "requiredProperties": [
                  "xbrla:intervalOfMeasurement",
                  "xbrla:timeSeriesType"
                ]
              }
            }
          ],
          "closed": true
        }
      },
      {
        "name": "xbrla:positionCube",
        "coreDimensions": [
          "xbrl:concept",
          "xbrl:period",
          "xbrl:unit",
          "xbrl:entity"
        ],
        "cubeDimensionConstraints": {
          "allowed": [
            {
              "type": "typed",
              "dataType": "xs:token",
              "minDimensions": 1
            }
          ],
          "closed": false
        }
      },
      {
        "name": "xbrla:listingCube",
        "coreDimensions": [
          "xbrl:concept",
          "xbrl:unit"
        ],
        "cubeDimensionConstraints": {
          "allowed": [
            {
              "type": "typed",
              "dataType": "xs:token",
              "minDimensions": 1
            }
          ],
          "closed": true
        }
      },
      {
        "name": "xbrla:referenceCube",
        "coreDimensions": [
          "xbrl:concept"
        ],
        "cubeDimensionConstraints": {
          "allowed": [
            {
              "type": "typed",
              "dataType": "xs:token",
              "minDimensions": 0,
              "maxDimensions": 1
            },
            {
              "type": "explicit",
              "minDimensions": 0,
              "maxDimensions": 1
            }
          ],
          "closed": true
        },
        "cubeNetworkConstraints": {
          "closed": false,
          "cubeNetworks": [
            {
              "relationshipType": "xbrl:concept-refDimension",
              "maxNetworks": 0,
              "target": {
                "qname": "xbrl:period"
              }
            }
          ]
        }
      }
    ],
    "labels": [
      {
        "labelType": "xbrl:label",
        "language": "en",
        "forObject": "xbrla:intervalConvention",
        "value": "Interval based on start or end time"
      },
      {
        "labelType": "xbrl:label",
        "language": "en",
        "forObject": "xbrla:intervalOfMeasurement",
        "value": "Measurement time interval"
      },
      {
        "labelType": "xbrl:documentation",
        "language": "en",
        "forObject": "xbrla:intervalOfMeasurement",
        "value": "A property that defines the frequency interval where data is sampled for use in a time series. If the data measurement is performed every day then the frequency of measurement will be a day. For an aggregated time series type this represents the interval over which all measurements are made and an aggregated value such as maximum, minimum, average, median etc are reported. For a raw time series this represents the interval between each measurement. The datetime dimension on a time series cube must include this property."
      },
      {
        "labelType": "xbrl:documentation",
        "language": "en",
        "forObject": "xbrla:completeTimeSeries",
        "value": "A boolean property that defines if the dimension used for a time series must have a value for every interval.  If true then every interval of the time series must have a fact. If false the time series does not have to be complete. If the property is not defined the default value is false."
      },
      {
        "labelType": "xbrl:label",
        "language": "en",
        "forObject": "xbrla:completeTimeSeries",
        "value": "Time series is complete"
      },
      {
        "labelType": "xbrl:label",
        "language": "en",
        "forObject": "xbrla:timeSeriesType",
        "value": "Time series type (Aggregated or Raw)"
      },
      {
        "labelType": "xbrl:documentation",
        "language": "en",
        "forObject": "xbrla:timeSeriesType",
        "value": "A string property that defines if the dimension used for a time series is raw data or aggregated data. The value of the property must be either Raw or Aggregated.  If no value is provided the default is Aggregated."
      },
      {
        "labelType": "xbrl:documentation",
        "language": "en",
        "forObject": "xbrla:instant-accrual",
        "value": "Relationship type linking instant and accrual concepts used for mapping or validation between instant and duration concepts."
      },
      {
        "labelType": "xbrl:documentation",
        "language": "en",
        "forObject": "xbrla:instant-inflow",
        "value": "Relationship type indicating an instant concept maps to a duration inflow concept."
      },
      {
        "labelType": "xbrl:documentation",
        "language": "en",
        "forObject": "xbrla:instant-outflow",
        "value": "Relationship type indicating an instant concept maps to a duration outflow concept."
      },
      {
        "labelType": "xbrl:documentation",
        "language": "en",
        "forObject": "xbrla:instant-contra",
        "value": "Relationship type indicating an instant concept is the contra (opposite sign) of a duration concept."
      },
      {
        "labelType": "xbrl:documentation",
        "language": "en",
        "forObject": "xbrla:eventCube",
        "value": "Cube type for single-event facts identified by a typed dimension; does not include standard period/entity/unit core dimensions."
      },
      {
        "labelType": "xbrl:documentation",
        "language": "en",
        "forObject": "xbrla:eventDetailsCube",
        "value": "Cube type for event detail records that reference concept-to-dimension relationships for richer typed dimensions."
      },
      {
        "labelType": "xbrl:documentation",
        "language": "en",
        "forObject": "xbrla:journalCube",
        "value": "A specialization of eventDetailsCube intended for journal or ledger style event records."
      },
      {
        "labelType": "xbrl:documentation",
        "language": "en",
        "forObject": "xbrla:referenceCube",
        "value": "Cube type used for reference or lookup data where facts act as descriptions rather than periodic measurements."
      },
      {
        "labelType": "xbrl:documentation",
        "language": "en",
        "forObject": "xbrla:timeSeriesCube",
        "value": "Cube type optimized for time-series data; requires a typed date/time dimension and typically includes the unit core-dimension."
      },
      {
        "labelType": "xbrl:documentation",
        "language": "en",
        "forObject": "xbrla:positionCube",
        "value": "Cube type for position-style facts that typically include period, entity and unit core dimensions."
      },
      {
        "forObject": "xbrla:intervalConventionType",
        "language": "en",
        "labelType": "xbrl:documentation",
        "value": "Used to identify the duration for a time series interval. Can be used to identify the interval by its start time or by its end time. If not provided on a dimension then the default is the start time. Start time is cCommon in IoT, databases, and time series analysis.  End time is common in finance time series analysis."
      },
      {
        "forObject": "xbrla:timeSeriesDataType",
        "language": "en",
        "labelType": "xbrl:documentation",
        "value": "Used to identify if the time series is recording raw data or aggregated data. Possible values are Raw or Aggregated. Raw data is collected at the defined interval as a single measurement. This data is usually highly voluminous. Aggregated time series data is used with continuous or high-frequency data (say, every second), but only stores one value per interval (like an hour), the value used within that period must be an aggregation such  as: Max - the highest observed value in the hour (e.g., max temperature). Min - the lowest observed value in the hour (e.g., min heart rate). First - the earliest value recorded in that hour (open price in finance). Last - the latest value recorded in that hour (close price in finance). Mean / Sum, Median, and  Percentile are other forms of possible aggregation. The aggregation performed should be associated with the concept recording the measurement as an aggregation property."
      },
      {
        "forObject": "xbrla:sharesType",
        "language": "en",
        "labelType": "xbrl:documentation",
        "value": "This data type serves as the data type for share based financial concepts."
      },
      {
        "labelType": "xbrl:label",
        "language": "en",
        "forObject": "xbrla:MonetaryPerShare",
        "value": "Monetary/share"
      },
      {
        "labelType": "xbrl:documentation",
        "language": "en",
        "forObject": "xbrla:MonetaryPerShare",
        "value": "Monetary Unit / Share"
      },
      {
        "labelType": "xbrl:label",
        "language": "en",
        "forObject": "xbrla:shares",
        "value": "Share"
      },
      {
        "labelType": "xbrl:documentation",
        "language": "en",
        "forObject": "xbrla:shares",
        "value": "Unit of Ownership (Stock)"
      }
    ],
    "networks": [
      {
        "name": "xbrla:dependentPropertiesNetwork",
        "relationshipTypeName": "xbrl:property-dependentProperty",
        "relationships": [
          {
            "source": "xbrl:rootSource",
            "target": "xbrla:intervalConvention"
          },
          {
            "source": "xbrl:rootSource",
            "target": "xbrla:timeSeriesType"
          },
          {
            "source": "xbrl:rootSource",
            "target": "xbrla:completeTimeSeries"
          },
          {
            "source": "xbrla:intervalConvention",
            "target": "xbrla:intervalOfMeasurement"
          },
          {
            "source": "xbrla:timeSeriesType",
            "properties": [
              {
                "property": "xbrl:propertyValue",
                "value": "Aggregated"
              }
            ],
            "target": "xbrl:aggregation"
          },
          {
            "source": "xbrla:completeTimeSeries",
            "properties": [
              {
                "property": "xbrl:propertyValue",
                "value": "true"
              }
            ],
            "target": "xbrla:intervalOfMeasurement"
          }
        ]
      }
    ],
    "references": [
      {
        "name": "xbrla:PerUnitAccountingReference",
        "forObjects": [
          "xbrla:MonetaryPerShare"
        ],
        "referenceType": "xbrl:dataTypeRequirement",
        "properties": [
          {
            "property": "ref:Requirement",
            "value": "These types are required in order to enable validation and conversion of units (via the Unit Types Registry) for values that are expressed as a price per unit for various physical measures, and reflect industry-specific common practice."
          }
        ]
      }
    ]
  }
}
