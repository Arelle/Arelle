        "labels": [
            {
                "relatedName": "oime:invalidJSON",
                "language": "en",
                "value": "Invalid JSON",
                "labelType": "xbrl:label"
            },
            {
                "relatedName": "oime:invalidJSON",
                "language": "en",
                "value": "The document is not valid JSON according to RFC 8259.",
                "labelType": "xbrl:errorMessage"
            },
            {
                "relatedName": "oime:invalidJSONStructure",
                "language": "en",
                "value": "Invalid JSON Structure",
                "labelType": "xbrl:label"
            },
            {
                "relatedName": "oime:invalidJSONStructure",
                "language": "en",
                "value": "The JSON structure does not conform to the required schema: {details}.",
                "labelType": "xbrl:errorMessage"
            },
            {
                "relatedName": "oime:invalidJSON",
                "language": "en",
                "value": "🚫",
                "labelType": "xbrl:iconLabel"
            },
            {
                "relatedName": "oime:invalidJSON",
                "language": "en",
                "value": "This error occurs when the taxonomy document is not valid JSON according to RFC 8259. The document must be well-formed JSON with proper syntax, including correct use of braces, brackets, quotes, commas, and escape sequences. The document must use UTF-8 encoding.",
                "labelType": "xbrl:documentation"
            },
            {
                "relatedName": "oime:invalidJSONStructure",
                "language": "en",
                "value": "🚫",
                "labelType": "xbrl:iconLabel"
            },
            {
                "relatedName": "oime:invalidJSONStructure",
                "language": "en",
                "value": "This error is generated when the JSON document's structure does not conform to the OIM Taxonomy schema requirements. Property values must match their specified JSON types (string, object, array, number). Required properties must be present. Values must conform to the specified model types, including proper lexical representations for XML Schema datatypes.",
                "labelType": "xbrl:documentation"
            },
            {
                "relatedName": "oime:disallowedDuplicateFacts",
                "language": "en",
                "value": "Disallowed Duplicate Facts",
                "labelType": "xbrl:label"
            },
            {
                "relatedName": "oime:disallowedDuplicateFacts",
                "language": "en",
                "value": "Prohibited duplicate facts are present in this report: {details}.",
                "labelType": "xbrl:errorMessage"
            },
            {
                "relatedName": "oime:disallowedDuplicateFacts",
                "language": "en",
                "value": "🚫",
                "labelType": "xbrl:iconLabel"
            },
            {
                "relatedName": "oime:disallowedDuplicateFacts",
                "language": "en",
                "value": "This error MAY be raised when duplicate facts that are prohibited are present in a model, as defined in section 6 of the Open Information Model 1.0 specification. Two facts are duplicate facts if, for every dimension in the dimensions property of one fact, the same dimension is present in the other fact with an equal dimension value and vice versa. The model defines whether duplicate facts are valid or invalid via the duplicateFactsInCube property of a cube object. If a duplicate fact exists in a model it must match the dimension values of at least one cube in the model that allows duplicate facts (complete duplicates, consistent duplicates, or inconsistent duplicates as permitted by that cube). If a duplicate fact does not match the dimension values of any cube that allows duplicates, this error MUST be raised.",
                "labelType": "xbrl:documentation"
            },
            {
                "relatedName": "oime:misplacedUnitDimension",
                "language": "en",
                "value": "Misplaced Unit Dimension",
                "labelType": "xbrl:label"
            },
            {
                "relatedName": "oime:misplacedUnitDimension",
                "language": "en",
                "value": "The xbrl:unit dimension must only be used with numeric facts: {details}.",
                "labelType": "xbrl:errorMessage"
            },
            {
                "relatedName": "oime:misplacedUnitDimension",
                "language": "en",
                "value": "🚫",
                "labelType": "xbrl:iconLabel"
            },
            {
                "relatedName": "oime:misplacedUnitDimension",
                "language": "en",
                "value": "This error is raised when the xbrl:unit dimension is present in the factDimensions of a fact whose concept has a non-numeric data type. A numeric fact is a fact object with a data type derived from xs:decimal, xs:double, or xs:float. Only numeric facts may carry a unit dimension; non-numeric facts (such as date, string, or boolean facts) MUST NOT include xbrl:unit in their factDimensions.",
                "labelType": "xbrl:documentation"
            },
            {
                "relatedName": "oime:missingPeriodDimension",
                "language": "en",
                "value": "Missing Period Dimension",
                "labelType": "xbrl:label"
            },
            {
                "relatedName": "oime:missingPeriodDimension",
                "language": "en",
                "value": "Fact '{factName}' is missing the required xbrl:period dimension. Concept '{conceptName}' has periodType '{periodType}' which requires a period dimension.",
                "labelType": "xbrl:errorMessage"
            },
            {
                "relatedName": "oime:missingPeriodDimension",
                "language": "en",
                "value": "🚫",
                "labelType": "xbrl:iconLabel"
            },
            {
                "relatedName": "oime:missingPeriodDimension",
                "language": "en",
                "value": "Raised when a fact's concept has a periodType of 'duration' or 'instant' but the fact does not include the xbrl:period dimension in its factDimensions. Facts whose concept has periodType 'none' MUST NOT include xbrl:period, but facts with periodType 'duration' or 'instant' MUST always include it.",
                "labelType": "xbrl:documentation"
            },
            {
                "relatedName": "oime:invalidPeriodDimension",
                "language": "en",
                "value": "Invalid Period Dimension",
                "labelType": "xbrl:label"
            },
            {
                "relatedName": "oime:invalidPeriodDimension",
                "language": "en",
                "value": "Fact '{factName}' has an xbrl:period value '{period}' that is inconsistent with the concept '{conceptName}' periodType '{periodType}'.",
                "labelType": "xbrl:errorMessage"
            },
            {
                "relatedName": "oime:invalidPeriodDimension",
                "language": "en",
                "value": "🚫",
                "labelType": "xbrl:iconLabel"
            },
            {
                "relatedName": "oime:invalidPeriodDimension",
                "language": "en",
                "value": "Raised when the xbrl:period value of a fact is inconsistent with the periodType of its concept. If periodType is 'duration', the period must be a non-zero time interval (e.g. '2023-01-01/2023-12-31'). If periodType is 'instant', the period must be a zero-length time interval (a single date, e.g. '2023-12-31'). If periodType is 'none', the xbrl:period dimension must not be present at all.",
                "labelType": "xbrl:documentation"
            }
        ],
